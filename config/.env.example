# Embedding provider: "openai" or "azure"
EMBED_PROVIDER=azure
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# Azure OpenAI (when EMBED_PROVIDER=azure)
AZURE_API_KEY=your-azure-api-key
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-01

# OpenAI (when EMBED_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key-here

# LLM provider for reasoning agent: "anthropic", "openai", or "azure"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Client library
TILTH_GATEWAY_URL=http://localhost:8001
TILTH_IDENTITY=test-writer

# MCP server
TILTH_QUERY_GATEWAY_URL=http://localhost:8002
TILTH_MCP_DEV_IDENTITY=dev-stdio-user
